# Hannah Smith — .env.example
# Copy to .env and fill in your values

# ── Hosted provider presets via `hannah configure` ─────
# Anthropic / Claude
HANNAH_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# HANNAH_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-proj-your-key-here

# Google / Gemini
# HANNAH_MODEL=gemini/gemini-2.0-flash
# GOOGLE_API_KEY=your-google-key-here

# ── Optional local OpenAI-compatible runtime ────────────
# HANNAH_MODEL=openai/rlm-local
# HANNAH_RLM_API_BASE=http://localhost:8000
# HANNAH_RLM_API_KEY=none

# ── Agent tuning ─────────────────────────────────────────
HANNAH_TEMPERATURE=0.2
HANNAH_MAX_TOKENS=2048

# ── Simulation ───────────────────────────────────────────
HANNAH_SIM_N_WORLDS=1000
